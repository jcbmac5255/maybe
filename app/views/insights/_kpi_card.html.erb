<%# locals: (label:, amount:, currency:, color:, delta: nil, delta_good: nil, comparison_label: nil) %>

<%
  amount_class = case color
    when "green" then "text-green-600"
    when "red"   then "text-red-600"
    else "text-primary"
  end

  delta_class = if delta.nil?
    "text-secondary"
  elsif delta_good && delta_good.call(delta)
    "text-green-600"
  else
    "text-red-600"
  end
  arrow = delta && delta > 0 ? "↑" : (delta && delta < 0 ? "↓" : "")
%>

<div class="bg-container shadow-border-xs rounded-xl p-4">
  <p class="text-xs uppercase text-secondary font-medium mb-1"><%= label %></p>
  <p class="text-2xl font-medium <%= amount_class %>"><%= format_money(Money.new(amount, currency)) %></p>
  <p class="text-xs mt-1 <%= delta_class %>">
    <% if delta.nil? %>
      <span class="text-secondary">No prior data</span>
    <% else %>
      <%= arrow %> <%= delta.abs %>%
      <span class="text-secondary"><%= comparison_label %></span>
    <% end %>
  </p>
</div>
