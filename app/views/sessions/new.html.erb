<%
  header_title t(".title")
%>

<div data-controller="passkey-login" class="space-y-3">
  <button type="button"
          data-action="click->passkey-login#login"
          class="w-full flex items-center justify-center gap-2 py-2 px-4 bg-container border border-secondary rounded-lg text-sm font-medium text-primary hover:bg-surface-hover">
    <%= icon "fingerprint", size: "sm" %>
    Sign in with passkey
  </button>
  <p class="text-xs text-destructive text-center" data-passkey-login-target="error"></p>
</div>

<div class="my-4 flex items-center gap-3">
  <div class="grow h-px bg-tertiary"></div>
  <span class="text-xs text-secondary uppercase">or with password</span>
  <div class="grow h-px bg-tertiary"></div>
</div>

<%= styled_form_with url: sessions_path, class: "space-y-4", data: { turbo: false } do |form| %>
  <%= form.email_field :email, label: t(".email"), autofocus: false, autocomplete: "email", required: "required", placeholder: t(".email_placeholder") %>

  <%= form.password_field :password, label: t(".password"), required: "required", placeholder: t(".password_placeholder") %>

  <%= form.submit t(".submit") %>
<% end %>

<div class="mt-6 text-center">
  <%= link_to t(".forgot_password"), new_password_reset_path, class: "font-medium text-sm text-primary hover:underline transition" %>
</div>
