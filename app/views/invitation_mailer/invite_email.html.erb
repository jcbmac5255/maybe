<h1 style="color: #1e293b; font-size: 24px; margin-bottom: 24px;"><%= t(".greeting") %></h1>

<p style="color: #475569; font-size: 16px; margin-bottom: 16px;">
  <%= t(".body",
    inviter: @invitation.inviter.display_name,
    family: @invitation.family.name).html_safe %>
</p>

<%= link_to t(".accept_button"), @accept_url, style: "background-color: #3b82f6; border-radius: 6px; color: #ffffff !important; display: inline-block; font-weight: 600; margin: 16px 0; padding: 12px 24px; text-decoration: none;" %>

<p style="color: #64748b; font-size: 14px; margin-top: 32px;">
  Or copy and paste this link into your browser:<br>
  <span style="color: #3b82f6; word-break: break-all;"><%= @accept_url %></span>
</p>

<p style="color: #64748b; font-size: 14px; margin-top: 16px;"><%= t(".expiry_notice", days: 3) %></p>
