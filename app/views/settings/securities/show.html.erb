<%= content_for :page_title, t(".page_title") %>

<%= settings_section title: t(".password_title"), subtitle: t(".password_description") do %>
  <div class="space-y-4">
    <div class="p-3 shadow-border-xs bg-container rounded-lg md:flex md:justify-between md:items-center">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-container-inset flex justify-center items-center">
          <%= icon "key-round" %>
        </div>

        <div class="text-sm space-y-1">
          <p class="text-primary">Password</p>
          <p class="text-secondary">Change the password you use to sign in.</p>
        </div>
      </div>

      <div class="mt-4 md:mt-0">
        <%= render DS::Link.new(
          text: t(".change_password"),
          variant: "secondary",
          href: edit_password_path
        ) %>
      </div>
    </div>
  </div>
<% end %>

<%= settings_section title: "Passkeys", subtitle: "Sign in with Face ID, Touch ID, fingerprint, or your device's PIN — no password needed." do %>
  <div class="space-y-3" data-controller="passkey-register">
    <% Current.user.webauthn_credentials.ordered.each do |cred| %>
      <div class="p-3 shadow-border-xs bg-container rounded-lg flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-container-inset flex justify-center items-center">
            <%= icon "fingerprint" %>
          </div>
          <div class="text-sm">
            <p class="text-primary"><%= cred.nickname || "Passkey" %></p>
            <p class="text-secondary text-xs">
              Added <%= cred.created_at.strftime("%b %-d, %Y") %>
              <% if cred.last_used_at %>
                · Last used <%= cred.last_used_at.strftime("%b %-d, %Y") %>
              <% end %>
            </p>
          </div>
        </div>
        <%= button_to webauthn_credential_path(cred), method: :delete,
              form: { data: { turbo_confirm: "Remove this passkey? You won't be able to sign in with this device until you add a new one." } },
              class: "text-secondary hover:text-destructive p-2 rounded" do %>
          <%= icon "trash-2", size: "sm" %>
        <% end %>
      </div>
    <% end %>

    <%= render DS::Button.new(
      text: "Add a passkey",
      variant: "secondary",
      icon: "plus",
      data: { action: "click->passkey-register#register" }
    ) %>
    <p class="text-xs text-destructive" data-passkey-register-target="error"></p>
  </div>
<% end %>

<%= settings_section title: t(".mfa_title"), subtitle: t(".mfa_description") do %>
  <div class="space-y-4">
    <div class="p-3 shadow-border-xs bg-container rounded-lg md:flex md:justify-between md:items-center">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-gray-25 flex justify-center items-center">
          <%= icon "shield-check" %>
        </div>

        <div class="text-sm space-y-1">
          <% if Current.user.otp_required? %>
            <p class="text-primary">Two-factor authentication is <span class="font-medium text-green-600">enabled</span></p>
            <p class="text-secondary">Your account is protected with an additional layer of security.</p>
          <% else %>
            <p class="text-primary">Two-factor authentication is <span class="font-medium text-red-600">disabled</span></p>
            <p class="text-secondary">Enable 2FA to add an extra layer of security to your account.</p>
          <% end %>
        </div>
      </div>

      <div class="mt-4 md:mt-0">
        <% if Current.user.otp_required? %>
          <%= render DS::Button.new(
            text: t(".disable_mfa"),
            variant: "secondary",
            href: disable_mfa_path,
            method: :delete,
            confirm: CustomConfirm.new(
              title: t(".disable_mfa_confirm"),
              body: t(".disable_mfa_confirm"),
              btn_text: t(".disable_mfa"),
              destructive: true
            )
          ) %>
        <% else %>
          <%= render DS::Link.new(
            text: t(".enable_mfa"),
            variant: "primary",
            href: new_mfa_path
          ) %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
